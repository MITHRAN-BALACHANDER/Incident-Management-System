# ─────────────────────────────────────────────
# PulseGuard — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://pulseguard:pulseguard_secret@localhost:5432/pulseguard

# MongoDB (Mongoose)
MONGO_URI=mongodb://pulseguard:pulseguard_secret@localhost:27017/pulseguard?authSource=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka
KAFKA_BROKERS=localhost:9092

# ─────────────────────────────────────────────
# Alert Strategies (optional — leave blank to disable)
# ─────────────────────────────────────────────

# Email (Nodemailer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=ops@pulseguard.io

# Slack
SLACK_WEBHOOK_URL=
